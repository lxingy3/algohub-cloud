DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
JURISDICTION_ID="pittsburgh"

# Replace DATABASE_URL with the pooled Neon connection string.
# Keep the real value in .env or Vercel environment variables, not in source control.

# Cloudflare R2 media uploads.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# OpenAI Whisper transcription.
OPENAI_API_KEY=""

# Optional shared secret for calling /api/transcription/process from a cron/job runner.
TRANSCRIPTION_PROCESS_SECRET=""

# Vercel Cron automatically sends this value as:
# Authorization: Bearer $CRON_SECRET
CRON_SECRET=""
