DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
JURISDICTION_ID="pittsburgh"

# Replace DATABASE_URL with the pooled Neon connection string.
# Keep the real value in .env or Vercel environment variables, not in source control.

# Auth.js / SSO.
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
MICROSOFT_ENTRA_ID_ID=""
MICROSOFT_ENTRA_ID_SECRET=""
MICROSOFT_ENTRA_ID_TENANT_ID=""

# Temporary test-phase compatibility: allows existing users with no password_hash
# to log in with an empty password and then set a password in-app.
ALLOW_LEGACY_EMPTY_PASSWORD_LOGIN="true"

# Password reset email. RESEND_API_KEY is required before reset emails can be sent.
PASSWORD_RESET_EMAIL_ENABLED="false"
RESEND_API_KEY=""
PASSWORD_RESET_FROM_EMAIL="AlgoStories <onboarding@resend.dev>"
PASSWORD_RESET_REPLY_TO="xil594@pitt.edu"

# Firebase Cloud Storage / Google Cloud Storage signed media URLs.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""

# Optional shared secret for calling /api/transcription/process from a future ML job runner.
TRANSCRIPTION_PROCESS_SECRET=""

# Vercel Cron automatically sends this value as:
# Authorization: Bearer $CRON_SECRET
CRON_SECRET=""
